{
  "manifest_version": 3,
  "name": "Email Archive Assistant",
  "version": "1.7.2",
  "description": "Archive inbox mail using local Ollama LLM and folder index (RAG)",
  "author": "Andrea Clementi with Cursor, Claude-Sonnet-3.5, o1",
  "browser_specific_settings": {
    "gecko": {
      "id": "email-archive@example.com",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background/ollama.js", "background/background.js"]
  },
  "permissions": [
    "accountsRead",
    "accountsFolders",
    "messagesRead",
    "messagesMove",
    "storage",
    "menus",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:11434/*",
    "http://localhost:11434/*"
  ],
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": false
  },
  "commands": {
    "open-assistant": {
      "description": "Open Email Archive Assistant",
      "suggested_key": {
        "default": "Alt+Shift+A"
      }
    }
  },
  "action": {
    "default_title": "Email Archive Assistant",
    "default_popup": "pages/action-popup.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png"
    }
  },
  "message_display_action": {
    "default_title": "Archive to folder",
    "default_popup": "pages/folder-picker.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png"
    }
  },
  "icons": {
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png"
  }
}
